generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================================================
// Auth
// ==========================================================================

// A user of the mobile app.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  attempts QuizAttempt[]
  sessions Session[]
}

// A logged-in session, identified to clients by an opaque bearer token.
// Only the token's hash is stored — a DB leak doesn't hand out usable tokens.
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user User @relation(fields: [userId], references: [id])
}

// ==========================================================================
// Shared taxonomy — used by both live quiz questions and staged import questions
// ==========================================================================

// Subject used for category-wise practice (History, Polity, Economy, ...).
model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  subcategories     Subcategory[]
  questions         Question[]
  draftQuestions    DraftQuestion[]
  attemptCategories AttemptCategory[]
}

// Finer-grained topic within a Category, used by the import/review pipeline.
model Subcategory {
  id         Int    @id @default(autoincrement())
  name       String
  categoryId Int

  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  draftQuestions DraftQuestion[]

  @@unique([name, categoryId])
}

// Free-form label attached to draft questions during import/review.
model Tag {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  questions QuestionTag[]
}

// ==========================================================================
// Live quiz-serving models
// ==========================================================================

// "Prelims GS1", "Prelims CSAT", "Mains GS1", etc.
// Kept as a table (not an enum) so new exam types can be added with a row insert, no migration.
model ExamType {
  id   Int    @id @default(autoincrement())
  code String @unique // e.g. "PRELIMS_GS1"
  name String // e.g. "Prelims General Studies I"

  papers QuestionPaper[]
}

// One official past-year paper, e.g. UPSC Prelims GS1 2026.
model QuestionPaper {
  id         Int     @id @default(autoincrement())
  year       Int
  examTypeId Int
  title      String? // optional display label

  examType  ExamType      @relation(fields: [examTypeId], references: [id])
  questions Question[]
  attempts  QuizAttempt[]

  @@unique([examTypeId, year])
}

// A reviewed, quiz-ready question. Populated either directly (seed-2026-prelims-gs1.ts)
// or promoted from a DraftQuestion once it clears review.
model Question {
  id              Int     @id @default(autoincrement())
  text            String
  explanation     String?
  categoryId      Int
  questionPaperId Int?

  category      Category        @relation(fields: [categoryId], references: [id])
  questionPaper QuestionPaper?  @relation(fields: [questionPaperId], references: [id])
  options       Option[]
  answers       AttemptAnswer[]

  createdAt DateTime @default(now())
}

model Option {
  id         Int     @id @default(autoincrement())
  questionId Int
  label      String // "A", "B", "C", "D"
  text       String
  isCorrect  Boolean @default(false)

  question          Question        @relation(fields: [questionId], references: [id])
  selectedInAnswers AttemptAnswer[]

  @@unique([questionId, label])
}

enum AttemptMode {
  FULL_PAPER
  CATEGORY_PRACTICE
}

// One quiz session — either replaying a full past paper or a mixed-category practice set.
model QuizAttempt {
  id              Int         @id @default(autoincrement())
  userId          String
  mode            AttemptMode
  questionPaperId Int? // set only when mode = FULL_PAPER
  startedAt       DateTime    @default(now())
  completedAt     DateTime?
  totalQuestions  Int
  correctCount    Int         @default(0)
  wrongCount      Int         @default(0)
  skippedCount    Int         @default(0)

  user          User              @relation(fields: [userId], references: [id])
  questionPaper QuestionPaper?    @relation(fields: [questionPaperId], references: [id])
  categories    AttemptCategory[]
  answers       AttemptAnswer[]
}

// Which categories were selected for a CATEGORY_PRACTICE attempt.
model AttemptCategory {
  id         Int @id @default(autoincrement())
  attemptId  Int
  categoryId Int

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id])
  category Category    @relation(fields: [categoryId], references: [id])

  @@unique([attemptId, categoryId])
}

// A single answered (or skipped) question within an attempt.
// Weak-category stats are computed on demand by joining this to Question -> Category,
// no separate stats table needed at this scale.
model AttemptAnswer {
  id               Int      @id @default(autoincrement())
  attemptId        Int
  questionId       Int
  selectedOptionId Int? // null = skipped
  isCorrect        Boolean  @default(false)
  answeredAt       DateTime @default(now())

  attempt        QuizAttempt @relation(fields: [attemptId], references: [id])
  question       Question    @relation(fields: [questionId], references: [id])
  selectedOption Option?     @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
}

// ==========================================================================
// Question-bank import / review pipeline
// Raw questions extracted from PDFs land here for human review before being
// promoted into the live Question/Option models above.
// ==========================================================================

model Paper {
  id        Int             @id @default(autoincrement())
  year      Int
  name      String // e.g., "GS1", "CSAT"
  set       String? // e.g., "A", "B", "C", "D"
  questions DraftQuestion[]
  imports   Import[]

  @@unique([year, name, set])
}

model DraftQuestion {
  id                 Int     @id @default(autoincrement())
  questionNo         Int
  text               String
  optionA            String?
  optionB            String?
  optionC            String?
  optionD            String?
  correctAnswer      String?

  explanation        String?
  explanationSource  String?
  reviewed           Boolean @default(false)

  questionImage      String?
  optionImage        String?
  imageType          String? // e.g., "MAP", "CHART", "TABLE", "DIAGRAM", "GENERAL"
  imageBoundingBox   String? // JSON string storing coordinates or OCR bbox

  parseConfidence    Float   @default(0.0)
  categoryConfidence Float   @default(0.0)
  answerConfidence   Float   @default(0.0)

  status             String  @default("NEEDS_REVIEW") // NEEDS_REVIEW or APPROVED

  paperId            Int
  paper              Paper       @relation(fields: [paperId], references: [id], onDelete: Cascade)

  categoryId         Int?
  category           Category?   @relation(fields: [categoryId], references: [id])

  subcategoryId      Int?
  subcategory        Subcategory? @relation(fields: [subcategoryId], references: [id])

  tags               QuestionTag[]
  reviewQueue        ReviewQueue?

  @@unique([paperId, questionNo])
}

model QuestionTag {
  questionId Int
  tagId      Int
  question   DraftQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
}

model Import {
  id        Int         @id @default(autoincrement())
  paperId   Int
  paper     Paper       @relation(fields: [paperId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  status    String // SUCCESS, PARTIAL, FAILED
  logs      ImportLog[]
}

model ImportLog {
  id        Int      @id @default(autoincrement())
  importId  Int
  import    Import   @relation(fields: [importId], references: [id], onDelete: Cascade)
  message   String
  level     String // INFO, WARN, ERROR
  createdAt DateTime @default(now())
}

model ReviewQueue {
  id         Int           @id @default(autoincrement())
  questionId Int           @unique
  question   DraftQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  reason     String // e.g., "Low Category Confidence", "Missing Options"
  resolved   Boolean       @default(false)
  createdAt  DateTime      @default(now())
}
